# Copy this file to .env for local development
# Never commit .env to git

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (use @userinfobot to get it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── GitHub (for local admin server — server.py) ───────────────────────────────
# Fine-grained PAT scoped to this repo only
# Required permissions: Actions (Read & Write), Contents (Read & Write)
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=your_github_pat_here

GITHUB_OWNER=ashishrahate
GITHUB_REPO=JobSeeker
